# ── Provider principal ─────────────────────────────────────────────────────────
# Opções: openrouter | gemini | anthropic
LLM_PROVIDER=openrouter

# ── OpenRouter (padrão — modelos gratuitos disponíveis) ────────────────────────
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── Gemini (assinatura Google One / Gemini Pro) ────────────────────────────────
# GEMINI_API_KEY=AIza...

# ── Anthropic (fallback opcional) ─────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...

# ── Modelos por tarefa (deixe vazio para usar os defaults do provider) ─────────
# Default de todos: anthropic/claude-sonnet-4.6 via OpenRouter
# Sobrescreva para reduzir custo (ex: google/gemini-2.5-flash-lite para refine)
MODEL_REFINE=
MODEL_GLOSSARY=
MODEL_CONSOLIDATE_GLOSSARY=
MODEL_STRUCTURE=
MODEL_CONSOLIDATE=

# ── Infraestrutura ─────────────────────────────────────────────────────────────
# Whisper — padrão: medium (~1.5 GB RAM). Use small (~470 MB) ou base (~140 MB) se necessário.
WHISPER_MODEL=medium      # tiny | base | small | medium | large
AUDIO_CHUNK_MB=24
DATA_DIR=./data/niches
BACKEND_URL=http://localhost:8000

# ── Modelos recomendados via OpenRouter ───────────────────────────────────────
# Com BYOK Google (Gemini) — usa sua cota direta, sem rate limit compartilhado:
#   google/gemini-2.5-flash-lite   (leve, barato, 1M ctx — refine/glossary)
#   google/gemini-2.5-flash        (forte, 1M ctx — structure/consolidate)
#   google/gemini-2.5-pro          (máxima qualidade, mais caro)
#   google/gemini-2.0-flash-001    (alternativa mais barata)
#
# Para ativar BYOK: openrouter.ai/settings/integrations → adicionar Google API key
# Para ver lista atualizada: GET https://openrouter.ai/api/v1/models
